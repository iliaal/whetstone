{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/inject-skills.sh",
            "timeout": 5,
            "statusMessage": "Injecting relevant skills..."
          }
        ]
      }
    ]
  }
}
